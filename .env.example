PORT=3000
OLLAMA_BASE_URL=http://localhost:11434

# Model to use for SQL generation via Ollama.
# smollm2:135m  — 135MB, very fast, may fail on complex queries
# qwen2.5-coder:1.5b — ~900MB, much better SQL accuracy (RECOMMENDED)
# deepseek-coder:1.3b — ~770MB, good SQL accuracy
MODEL_NAME=smollm2:135m

MAX_MODEL_SIZE_MB=1500
MODEL_TIMEOUT_MS=60000
MODEL_PULL_TIMEOUT_MS=600000
MODEL_TEMPERATURE=0.1
MODEL_MAX_TOKENS=512
AUTO_PULL_MODEL=true
ALLOW_WRITE_SQL=false

# Set to true and provide DATABASE_URL to run EXPLAIN on generated queries for accuracy verification
ENABLE_EXPLAIN_DRY_RUN=false
DATABASE_URL=

# Optional: path to a schema markdown file to load additional context
SCHEMA_DOC_PATH=
