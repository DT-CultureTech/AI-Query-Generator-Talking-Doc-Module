{
  "name": "ai-query-generator",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first natural language to PostgreSQL SQL generator with strict validation",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup:windows": "powershell -ExecutionPolicy Bypass -File .\\scripts\\setup-local.ps1",
    "setup:windows:no-start": "powershell -ExecutionPolicy Bypass -File .\\scripts\\setup-local.ps1 -NoStart",
    "smoke": "powershell -ExecutionPolicy Bypass -File .\\scripts\\smoke-test.ps1"
  },
  "dependencies": {
    "@types/pdf-parse": "^1.1.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "morgan": "^1.10.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.13.1",
    "pgsql-ast-parser": "^12.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
